# Public browser-safe configuration only.
NUXT_PUBLIC_APP_ORIGIN="http://localhost:3000"
NUXT_PUBLIC_DEMO_MODE="true"
NUXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NUXT_PUBLIC_SUPABASE_KEY="sb_publishable_your_key_here"

# Login-only access, verified exclusively by the Nuxt server.
NUXT_AUTH_USERNAME="admin"
NUXT_AUTH_PASSWORD="replace-with-a-long-random-password"
